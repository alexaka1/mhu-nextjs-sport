{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
    ':pinDependencies',
    'github>alexaka1/renovate-config',
    'github>alexaka1/renovate-config:monorepos',
    'github>alexaka1/renovate-config//opinionated/schedules',
    'github>alexaka1/renovate-config//opinionated/labels',
    'github>alexaka1/renovate-config//opinionated/security',
    ':automergeRequireAllStatusChecks',
    ':rebaseStalePrs',
    'security:minimumReleaseAgeNpm',
    ':automergePatch',
    ':automergeDigest',
  ],
  packageRules: [
    {
      description: 'Disable automatic updates for better-auth as patch version can contain breaking changes',
      matchDepNames: ['better-auth'],
      automerge: false,
    },
    {
      description: [
        "Ignore pnpm workspace overrides",
      ],
      matchManagers: ["npm"],
      matchDepTypes: ["pnpm-workspace.overrides"],
      matchFileNames: ["pnpm-workspace.yaml"],
      enabled: false,
    },
  ],
}
